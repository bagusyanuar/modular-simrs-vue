{
  "name": "@genrs/presentation",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./simrs/*": "./src/simrs/*",
    "./finance/*": "./src/finance/*",
    "./auth/*": "./src/auth/*"
  },
  "typesVersions": {
    "*": {
      "simrs/*": [
        "./src/simrs/*/index.ts",
        "./src/simrs/*.ts",
        "./src/simrs/*.vue",
        "./src/simrs/*"
      ],
      "finance/*": [
        "./src/finance/*/index.ts",
        "./src/finance/*.ts",
        "./src/finance/*.vue",
        "./src/finance/*"
      ],
      "auth/*": [
        "./src/auth/*/index.ts",
        "./src/auth/*.ts",
        "./src/auth/*.vue",
        "./src/auth/*"
      ]
    }
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.30",
    "tailwindcss": "^4.2.2",
    "@genrs/ui": "workspace:*",
    "@genrs/core": "workspace:*",
    "@genrs/infrastructure": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
