{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "outDir": "dist",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@genrs/core/*": ["../../features/core/src/*"],
      "@genrs/infrastructure/*": ["../../features/infrastructure/src/*"],
      "@genrs/auth": ["../../packages/auth/src/index.ts"],
      "@genrs/auth/*": ["../../packages/auth/src/*"],
      "@page/*": ["./src/simrs/base/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}
