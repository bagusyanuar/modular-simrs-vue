# ==============================================================================
# GLOBAL MONOREPO ENVIRONMENT VARIABLES
# ==============================================================================
# Variabel di sini akan tersedia secara global di semua shell app.
# Jika nama variabel sama dengan yang ada di .env lokal app, maka lokal yang menang.

VITE_GLOBAL_APP_NAME="Modular SIMRS Ecosystem"
VITE_GLOBAL_API_BASE_URL="http://localhost:8000/api/v1"
VITE_GLOBAL_MAINTENANCE=false

# AUTH SSO CONFIGURATION
VITE_AUTH_SSO_DOMAIN=".neurovi-simulation.test"
VITE_AUTH_SERVER_URL="http://neurovi-simulation.test:3000"

# SHELL APP PATHS
VITE_PATH_SSO="/sso"
VITE_PATH_V1="/"
VITE_PATH_V2="/v2"
