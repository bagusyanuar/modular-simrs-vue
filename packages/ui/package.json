{
  "name": "@genrs/ui",
  "version": "1.0.0",
  "type": "module",
  "description": "UI components for Gen SIMRS System",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*/index.ts",
    "./layouts": "./src/layouts/index.ts",
    "./composables": "./src/composables/index.ts",
    "./utils": "./src/components/lib/utils.ts",
    "./icons": "./src/components/icons/index.ts"
  },
  "imports": {
    "#components/*": "./src/components/*",
    "#lib/*": "./src/components/lib/*",
    "#icons/*": "./src/components/icons/*"
  },
  "typesVersions": {
    "*": {
      "components/*": ["./src/components/*/index.ts"],
      "layouts": ["./src/layouts/index.ts"],
      "utils": ["./src/components/lib/utils.ts"],
      "icons": ["./src/components/icons/index.ts"],
      "composables": ["./src/composables/index.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dist": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build:dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/vue3-vite": "^10.2.10",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint-plugin-storybook": "^10.2.10",
    "storybook": "^10.2.10",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@internationalized/date": "^3.12.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30",
    "vue-sonner": "^2.0.9"
  }
}
