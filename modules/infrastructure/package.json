{
  "name": "@genossys-hospital/infrastructure",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "exports": {
    "./*": [
      "./src/*/index.ts",
      "./src/*.ts",
      "./src/*"
    ]
  },
  "typesVersions": {
    "*": {
      "/*": [
        "./src/*/index.ts",
        "./src/*.ts",
        "./src/*"
      ]
    }
  },
  "dependencies": {
    "@genossys-hospital/core": "workspace:*",
    "@genossys-hospital/sso-sdk": "workspace:*",
    "@genossys-hospital/http-sdk": "workspace:*",
    "@genrs/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "~5.9.3"
  }
}
